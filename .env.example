# Copy this to .env and fill in your values
# cp .env.example .env

# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenSearch — defaults match docker-compose.yml
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# Neo4j — defaults match docker-compose.yml
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=bugraidpassword

# Path to the MELT telemetry file (loaded into memory at startup)
MELT_DATA_PATH=data/melt_telemetry.json

# Confidence threshold to stop iterating early (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.85

# Max retrieval iterations (assessment requires up to 3)
MAX_ITERATIONS=3
