// ─── DEPENDS_ON relationships ─────────────────────────────────────────────
MATCH (a:Service {name: "checkout-svc"}), (b:Service {name: "payment-svc"}) CREATE (a)-[:DEPENDS_ON {latency_ms: 45, criticality: "critical"}]->(b);
